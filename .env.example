# Copy to .env and fill in. The reports pipeline reads these from the environment.
# (.env is gitignored. Load it however you prefer — e.g. `set -a; . ./.env; set +a`.)

# --- Gemini (Phase 4 synthesis) ---
# Pick ONE of the two auth styles below.

# Option A: Vertex AI (workplace GCP project). Needs Application Default
# Credentials (`gcloud auth application-default login`) OR a Vertex express-mode
# API key in GOOGLE_API_KEY.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
# GOOGLE_API_KEY=...           # only if using a Vertex express-mode API key

# Option B: Gemini Developer API (key from aistudio.google.com). Leave
# GOOGLE_GENAI_USE_VERTEXAI unset/false and set just the key:
# GOOGLE_API_KEY=...

# Model (optional; default gemini-2.5-pro)
GEMINI_MODEL=gemini-2.5-pro

# --- Email delivery (Phase 4 reports) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
# Gmail: create an App Password (Account -> Security -> App passwords), not your login password.
SMTP_PASS=your-app-password
REPORT_FROM=you@gmail.com
REPORT_TO=you@gmail.com
