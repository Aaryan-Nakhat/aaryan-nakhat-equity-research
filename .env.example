# Copy to .env and fill in. The reports pipeline reads these from the environment.
# (.env is gitignored. Load it however you prefer — e.g. `set -a; . ./.env; set +a`.)

# --- Claude (Phase 4 synthesis) ---
# Get a key at https://console.anthropic.com/ -> API keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Email delivery (Phase 4 reports) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
# Gmail: create an App Password (Account -> Security -> App passwords), not your login password.
SMTP_PASS=your-app-password
REPORT_FROM=you@gmail.com
REPORT_TO=you@gmail.com
