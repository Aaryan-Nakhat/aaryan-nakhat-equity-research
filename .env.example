# Copy to .env and fill in. The reports pipeline reads these from the environment.
# (.env is gitignored. Load it however you prefer — e.g. `set -a; . ./.env; set +a`.)

# --- Gemini (Phase 4 synthesis) ---
# Pick ONE of the two auth styles below.

# Option A: Vertex AI (workplace GCP project) via a SERVICE ACCOUNT.
# Put the key in gcp-service-account.json (gitignored) and point to it here.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global         # e.g. global, us-central1, asia-south1
GCP_SERVICE_ACCOUNT_FILE=./gcp-service-account.json
# (GOOGLE_APPLICATION_CREDENTIALS is honoured too; or omit both to use
#  `gcloud auth application-default login` ADC.)

# Option B: Gemini Developer API (key from aistudio.google.com). Leave
# GOOGLE_GENAI_USE_VERTEXAI unset/false and set just the key:
# GOOGLE_API_KEY=...

# Model (optional; default gemini-2.5-pro)
GEMINI_MODEL=gemini-2.5-pro

# --- Telegram bot (interactive reports) ---
# Create a bot with @BotFather -> /newbot -> copy the token here.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# Your numeric Telegram user ID(s), comma-separated. Get it from @userinfobot.
# Only these users are served (everyone else is ignored).
TELEGRAM_ALLOWED_USERS=123456789

# --- Email delivery (Phase 4 reports) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
# Gmail: create an App Password (Account -> Security -> App passwords), not your login password.
SMTP_PASS=your-app-password
REPORT_FROM=you@gmail.com
REPORT_TO=you@gmail.com
